{
  "request": {
    "method": "POST",
    "urlPathPattern": "^(/v1/chat/completions|/chat/completions)$",
    "headers": {
      "X-Threlium-Call-Site": {
        "equalTo": "reasoning"
      }
    },
    "bodyPatterns": [
      {
        "matches": "(?s).*(openai/threlium_e2e_l0|threlium_e2e_l0).*"
      },
      {
        "contains": "<envelope>"
      },
      {
        "contains": "\"tools\""
      },
      {
        "comment": "enrich_fast \u043d\u0430\u043a\u0430\u043f\u043b\u0438\u0432\u0430\u0435\u0442 relay-\u0447\u0430\u0441\u0442\u0438: observation \u043e\u0442 formal_reason (hop1) \u041d\u0415 \u0437\u0430\u0442\u0451\u0440\u0442\u0430 observation \u043e\u0442 memory_query (hop2). \u041e\u0431\u0430 \u043c\u0430\u0440\u043a\u0435\u0440\u0430 \u043e\u0431\u044f\u0437\u0430\u043d\u044b \u043f\u0440\u0438\u0441\u0443\u0442\u0441\u0442\u0432\u043e\u0432\u0430\u0442\u044c \u0432 \u043f\u0440\u043e\u043c\u043f\u0442\u0435 3-\u0433\u043e reasoning.",
        "contains": "conforms: True"
      },
      {
        "contains": "SHACL-SPARQL reference after successful validation"
      },
      {
        "comment": "unified-delta durability: \u0434\u0435\u043b\u044c\u0442\u0430 1-\u0433\u043e \u0446\u0438\u043a\u043b\u0430 (\u0432\u0445\u043e\u0434 formal_reason, ex:PositiveAgeShape) \u043f\u0435\u0440\u0435\u043d\u0435\u0441\u0435\u043d\u0430 \u0432 E_prev \u0447\u0435\u0440\u0435\u0437 \u0447\u0430\u0441\u0442\u0438 \u043f\u0440\u043e\u0448\u043b\u043e\u0433\u043e enrich_fast \u0438 \u0432\u0438\u0434\u043d\u0430 \u0432 \u043f\u0440\u043e\u043c\u043f\u0442\u0435 4-\u0433\u043e reasoning (finalize) \u0432\u043c\u0435\u0441\u0442\u0435 \u0441 \u0434\u0435\u043b\u044c\u0442\u043e\u0439 2-\u0433\u043e \u0446\u0438\u043a\u043b\u0430 (\u0432\u0445\u043e\u0434 memory_query).",
        "contains": "ex:PositiveAgeShape"
      }
    ],
    "customMatcher": {
      "name": "state-matcher",
      "parameters": {
        "hasContext": "stub-formal-reason-chain-01::{{request.headers.[X-Threlium-Thread-Root]}}",
        "hasProperty": "phase_query_done_ledger_done"
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "transformers": [
      "response-template"
    ],
    "jsonBody": {
      "id": "chatcmpl-e2e-formal-reason-reasoning-3-finalize",
      "object": "chat.completion",
      "created": 0,
      "model": "gpt-4o-mini",
      "choices": [
        {
          "index": 0,
          "finish_reason": "tool_calls",
          "message": {
            "role": "assistant",
            "content": null,
            "tool_calls": [
              {
                "id": "call_e2e_response_finalize_logic",
                "type": "function",
                "function": {
                  "name": "response_finalize",
                  "arguments": "{\"reasoning\": \"e2e: finalizing after logic validation and knowledge query\", \"subject\": \"Re: e2e reply\", \"verification_summary\": \"e2e: logic conforms, knowledge queried successfully\", \"content\": \"e2e-formal-reason-verified-answer\"}"
                }
              }
            ]
          }
        }
      ]
    }
  },
  "serveEventListeners": [
    {
      "name": "recordState",
      "parameters": {
        "context": "{{request.headers.[X-Threlium-Thread-Root]}}",
        "list": {
          "addLast": {
            "cs": "{{request.headers.[X-Threlium-Call-Site]}}"
          }
        },
        "state": {
          "saw_delta_section": "{{#if (contains request.body '<conversation_delta>')}}1{{else}}{{state context=request.headers.[X-Threlium-Thread-Root] property='saw_delta_section' default='0'}}{{/if}}",
          "saw_delta_shape": "{{#if (contains request.body 'ex:PositiveAgeShape')}}1{{else}}{{state context=request.headers.[X-Threlium-Thread-Root] property='saw_delta_shape' default='0'}}{{/if}}",
          "saw_mq_shacl": "{{#if (contains request.body 'SHACL sh:sparql constraint SELECT variable binding')}}1{{else}}{{state context=request.headers.[X-Threlium-Thread-Root] property='saw_mq_shacl' default='0'}}{{/if}}"
        }
      }
    }
  ]
}
