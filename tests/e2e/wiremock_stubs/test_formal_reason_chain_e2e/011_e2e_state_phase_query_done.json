{
  "request": {
    "method": "POST",
    "urlPath": "/__threlium/e2e/state/phase_query_done"
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "ok": true,
      "context": "{{jsonPath request.body '$.correlation_key'}}"
    }
  },
  "serveEventListeners": [
    {
      "name": "recordState",
      "parameters": {
        "context": "{{jsonPath request.body '$.correlation_key'}}",
        "state": {
          "phase_query_done": "1"
        }
      }
    }
  ]
}
