{
  "request": {
    "method": "POST",
    "urlPathPattern": "^(/v1/chat/completions|/chat/completions)$",
    "headers": {
      "X-Threlium-Call-Site": {
        "equalTo": "reasoning"
      }
    },
    "bodyPatterns": [
      {
        "matches": "(?s).*(openai/threlium_e2e_l0|threlium_e2e_l0).*"
      },
      {
        "contains": "<envelope>"
      },
      {
        "contains": "\"tools\""
      },
      {
        "contains": "E2E-FORMAL-REASON-CHAIN-BODY"
      },
      {
        "comment": "\u041f\u043e\u0432\u0442\u043e\u0440\u043d\u044b\u0435 completion \u0432 \u0442\u043e\u043c \u0436\u0435 _decide \u043f\u043e\u0441\u043b\u0435 recordState phase_formal_reason_done \u0443 100_: \u0442\u0435\u043b\u043e \u0431\u0435\u0437 conforms, \u0444\u0430\u0437\u0430 \u0443\u0436\u0435 \u0432\u044b\u0441\u0442\u0430\u0432\u043b\u0435\u043d\u0430.",
        "doesNotContain": "conforms: True"
      },
      {
        "comment": "2-\u0439 reasoning (memory_query): unified-delta \u0443\u0436\u0435 \u043d\u0435\u0441\u0451\u0442 ex:PositiveAgeShape \u2014 \u043e\u0442\u0434\u0430\u0451\u043c 101_, \u043d\u0435 retry formal_reason.",
        "doesNotContain": "ex:PositiveAgeShape"
      }
    ],
    "customMatcher": {
      "name": "state-matcher",
      "parameters": {
        "hasContext": "{{request.headers.[X-Threlium-Thread-Root]}}",
        "hasProperty": "phase_formal_reason_done",
        "hasNotProperty": "phase_query_done"
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "transformers": [
      "response-template"
    ],
    "jsonBody": {
      "id": "chatcmpl-e2e-formal-reason-reasoning-1-retry",
      "object": "chat.completion",
      "created": 0,
      "model": "gpt-4o-mini",
      "choices": [
        {
          "index": 0,
          "finish_reason": "tool_calls",
          "message": {
            "role": "assistant",
            "content": null,
            "tool_calls": [
              {
                "id": "call_e2e_formal_reason_1",
                "type": "function",
                "function": {
                  "name": "formal_reason",
                  "arguments": "{\"reasoning\": \"e2e: verifying temporal ordering invariant with SHACL-SPARQL; target shape ex:PositiveAgeShape\", \"shapes_ttl\": \"@prefix sh: <http://www.w3.org/ns/shacl#> .\\n@prefix ex: <http://example.org/> .\\n\\nex:PositiveAgeShape a sh:NodeShape ;\\n  sh:targetClass ex:Person ;\\n  sh:property [\\n    sh:path ex:age ;\\n    sh:minInclusive 0 ;\\n    sh:message \\\"Age must be non-negative\\\" ;\\n  ] .\", \"facts_ttl\": \"@prefix ex: <http://example.org/> .\\n\\nex:alice a ex:Person ;\\n  ex:age 30 .\\n\\nex:bob a ex:Person ;\\n  ex:age 25 .\"}"
                }
              }
            ]
          }
        }
      ]
    }
  },
  "serveEventListeners": [
    {
      "name": "recordState",
      "parameters": {
        "context": "{{request.headers.[X-Threlium-Thread-Root]}}",
        "list": {
          "addLast": {
            "cs": "{{request.headers.[X-Threlium-Call-Site]}}"
          }
        },
        "state": {
          "saw_delta_section": "{{#if (contains request.body '<conversation_delta>')}}1{{else}}{{state context=request.headers.[X-Threlium-Thread-Root] property='saw_delta_section' default='0'}}{{/if}}",
          "saw_delta_shape": "{{#if (contains request.body 'ex:PositiveAgeShape')}}1{{else}}{{state context=request.headers.[X-Threlium-Thread-Root] property='saw_delta_shape' default='0'}}{{/if}}",
          "saw_mq_shacl": "{{#if (contains request.body 'SHACL sh:sparql constraint SELECT variable binding')}}1{{else}}{{state context=request.headers.[X-Threlium-Thread-Root] property='saw_mq_shacl' default='0'}}{{/if}}"
        }
      }
    }
  ]
}
