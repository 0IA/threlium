{
  "request": {
    "method": "POST",
    "urlPathPattern": "^(/v1/chat/completions|/chat/completions)$",
    "headers": {
      "X-Threlium-Call-Site": {
        "equalTo": "reasoning"
      }
    },
    "bodyPatterns": [
      {
        "matches": "(?s).*(openai/threlium_e2e_l0|threlium_e2e_l0).*"
      },
      {
        "contains": "<envelope>"
      },
      {
        "contains": "\"tools\""
      },
      {
        "contains": "conforms: True"
      },
      {
        "comment": "unified-delta: \u0432\u0445\u043e\u0434 reasoning -> formal_reason (\u043f\u043e\u043b\u043d\u044b\u0439 shapes_ttl) \u043f\u043e\u043f\u0430\u0434\u0430\u0435\u0442 \u0432 \u043f\u0440\u043e\u043c\u043f\u0442 2-\u0433\u043e reasoning \u0447\u0435\u0440\u0435\u0437 <conversation_delta>. \u041c\u0430\u0440\u043a\u0435\u0440 ex:PositiveAgeShape \u0435\u0441\u0442\u044c \u0442\u043e\u043b\u044c\u043a\u043e \u0432\u043e \u0432\u0445\u043e\u0434\u0435 \u0441\u0442\u0430\u0434\u0438\u0438, \u043d\u0435 \u0432 observation-note (\u0442\u0430 \u043e\u043f\u0443\u0441\u043a\u0430\u0435\u0442 shapes/facts_ttl).",
        "contains": "ex:PositiveAgeShape"
      }
    ],
    "customMatcher": {
      "name": "state-matcher",
      "parameters": {
        "hasContext": "{{request.headers.[X-Threlium-Thread-Root]}}",
        "hasProperty": "phase_formal_reason_done",
        "hasNotProperty": "phase_query_done"
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "transformers": [
      "response-template"
    ],
    "jsonBody": {
      "id": "chatcmpl-e2e-formal-reason-reasoning-2",
      "object": "chat.completion",
      "created": 0,
      "model": "gpt-4o-mini",
      "choices": [
        {
          "index": 0,
          "finish_reason": "tool_calls",
          "message": {
            "role": "assistant",
            "content": null,
            "tool_calls": [
              {
                "id": "call_e2e_memory_query_1",
                "type": "function",
                "function": {
                  "name": "memory_query",
                  "arguments": "{\"reasoning\": \"e2e: querying knowledge base for SHACL-SPARQL reference after successful validation\", \"query\": \"SHACL sh:sparql constraint SELECT variable binding\"}"
                }
              }
            ]
          }
        }
      ]
    }
  },
  "serveEventListeners": [
    {
      "name": "recordState",
      "parameters": {
        "context": "{{request.headers.[X-Threlium-Thread-Root]}}",
        "state": {
          "phase_query_done": "1"
        }
      }
    },
    {
      "name": "recordState",
      "parameters": {
        "context": "{{request.headers.[X-Threlium-Thread-Root]}}",
        "list": {
          "addLast": {
            "cs": "{{request.headers.[X-Threlium-Call-Site]}}"
          }
        },
        "state": {
          "saw_delta_section": "{{#if (contains request.body '<conversation_delta>')}}1{{else}}{{state context=request.headers.[X-Threlium-Thread-Root] property='saw_delta_section' default='0'}}{{/if}}",
          "saw_delta_shape": "{{#if (contains request.body 'ex:PositiveAgeShape')}}1{{else}}{{state context=request.headers.[X-Threlium-Thread-Root] property='saw_delta_shape' default='0'}}{{/if}}",
          "saw_mq_shacl": "{{#if (contains request.body 'SHACL sh:sparql constraint SELECT variable binding')}}1{{else}}{{state context=request.headers.[X-Threlium-Thread-Root] property='saw_mq_shacl' default='0'}}{{/if}}"
        }
      }
    }
  ]
}
