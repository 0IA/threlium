{
  "request": {
    "method": "POST",
    "urlPathPattern": "^(/v1/chat/completions|/chat/completions)$",
    "headers": {
      "X-Threlium-Call-Site": {
        "equalTo": "fsm"
      }
    },
    "bodyPatterns": [
      {
        "matches": "(?s).*(openai/threlium_e2e_l0|threlium_e2e_l0).*"
      },
      {
        "contains": "\"tools\""
      },
      {
        "contains": "ingress_distill"
      }
    ],
    "customMatcher": {
      "name": "state-matcher",
      "parameters": {
        "hasContext": "stub-formal-reason-chain-01::{{request.headers.[x-threlium-thread-root]}}"
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "id": "chatcmpl-e2e-formal-reason-ingress-distill",
      "object": "chat.completion",
      "created": 0,
      "model": "gpt-4o-mini",
      "choices": [
        {
          "index": 0,
          "finish_reason": "tool_calls",
          "message": {
            "role": "assistant",
            "content": null,
            "tool_calls": [
              {
                "id": "call_ingress_distill_e2e_formal_reason",
                "type": "function",
                "function": {
                  "name": "ingress_distill",
                  "arguments": "{\"user_query\":\"E2E-FORMAL-REASON-CHAIN-BODY: validate SHACL shapes and run formal_reason chain with memory_query follow-up.\",\"user_reply_language\":\"English\",\"open_gaps\":[],\"step_back_notes\":[\"Formal reason chain e2e ingress distill.\"]}"
                }
              }
            ]
          }
        }
      ]
    }
  }
}
