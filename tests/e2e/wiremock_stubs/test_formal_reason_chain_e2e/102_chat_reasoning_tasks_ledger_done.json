{
  "request": {
    "method": "POST",
    "urlPathPattern": "^(/v1/chat/completions|/chat/completions)$",
    "headers": {
      "X-Threlium-Call-Site": {
        "equalTo": "reasoning"
      },
      "X-Threlium-Litellm-Req-Seq": {
        "equalTo": "9"
      }
    },
    "bodyPatterns": [
      {
        "matches": "(?s).*(openai/threlium_e2e_l0|threlium_e2e_l0).*"
      },
      {
        "contains": "<envelope>"
      },
      {
        "contains": "\"tools\""
      },
      {
        "comment": "enrich_fast накапливает relay-части: observation от formal_reason (hop1) НЕ затёрта observation от memory_query (hop2). Оба маркера обязаны присутствовать в промпте 3-го reasoning.",
        "contains": "conforms: True"
      },
      {
        "contains": "SHACL-SPARQL reference after successful validation"
      },
      {
        "comment": "unified-delta durability: дельта 1-го цикла (вход formal_reason, ex:PositiveAgeShape) перенесена через части прошлых enrich_fast и видна в промпте 3-го reasoning (tasks_upsert) вместе с дельтой 2-го цикла (вход memory_query).",
        "contains": "ex:PositiveAgeShape"
      }
    ],
    "customMatcher": {
      "name": "state-matcher",
      "parameters": {
        "hasContext": "stub-formal-reason-chain-01::{{request.headers.[X-Threlium-Thread-Root]}}",
        "hasProperty": "active"
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "transformers": [
      "response-template"
    ],
    "jsonBody": {
      "id": "chatcmpl-e2e-tasks-ledger-phase_query_done_ledger_done",
      "object": "chat.completion",
      "created": 0,
      "model": "gpt-4o-mini",
      "choices": [
        {
          "index": 0,
          "finish_reason": "tool_calls",
          "message": {
            "role": "assistant",
            "content": null,
            "tool_calls": [
              {
                "id": "call_e2e_tasks_ledger_phase_query_done_ledger_done",
                "type": "function",
                "function": {
                  "name": "tasks_upsert",
                  "arguments": "{\"reasoning\": \"e2e: record task completion before finalize\",\"new_subtasks\": [{\"text\": \"Complete the user request\",\"status\": \"done\"}]}"
                }
              }
            ]
          }
        }
      ]
    }
  },
  "serveEventListeners": [
    {
      "name": "recordState",
      "parameters": {
        "context": "{{#if (contains request.body '<conversation_delta>')}}saw-delta-section-{{request.headers.[X-Threlium-Thread-Root]}}{{else}}_no_saw_delta_section{{/if}}",
        "list": {
          "addLast": {
            "hit": "1"
          }
        }
      }
    },
    {
      "name": "recordState",
      "parameters": {
        "context": "{{#if (contains request.body 'ex:PositiveAgeShape')}}saw-delta-shape-{{request.headers.[X-Threlium-Thread-Root]}}{{else}}_no_saw_delta_shape{{/if}}",
        "list": {
          "addLast": {
            "hit": "1"
          }
        }
      }
    },
    {
      "name": "recordState",
      "parameters": {
        "context": "{{#if (contains request.body 'SHACL sh:sparql constraint SELECT variable binding')}}saw-mq-shacl-{{request.headers.[X-Threlium-Thread-Root]}}{{else}}_no_saw_mq_shacl{{/if}}",
        "list": {
          "addLast": {
            "hit": "1"
          }
        }
      }
    }
  ]
}
