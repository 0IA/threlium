{
  "request": {
    "method": "POST",
    "urlPathPattern": "^(/v1/chat/completions|/chat/completions)$",
    "headers": {
      "X-Threlium-Call-Site": {
        "equalTo": "fsm"
      }
    },
    "bodyPatterns": [
      {
        "matches": "(?s).*(openai/threlium_e2e_l0|threlium_e2e_l0).*"
      },
      {
        "contains": "<envelope>"
      },
      {
        "contains": "\"tools\""
      },
      {
        "comment": "First reasoning: close A, leave B in_progress, set blockers + allow_finalize_with_blocker — gate must allow finalize despite open B.",
        "contains": "E2E-TASK-LEDGER-BYPASS-BODY"
      },
      {
        "doesNotMatch": "(?s).*\"enable_thinking\"\\s*:\\s*false.*"
      }
    ],
    "customMatcher": {
      "name": "state-matcher",
      "parameters": {
        "hasContext": "stub-task-ledger-bypass-01::{{request.headers.[x-threlium-thread-root]}}",
        "hasProperty": "active",
        "hasNotProperty": "phase_bypass_upsert_done"
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "id": "chatcmpl-e2e-task-ledger-bypass-upsert",
      "object": "chat.completion",
      "created": 0,
      "model": "gpt-4o-mini",
      "choices": [
        {
          "index": 0,
          "finish_reason": "tool_calls",
          "message": {
            "role": "assistant",
            "content": null,
            "tool_calls": [
              {
                "id": "call_e2e_tasks_upsert_bypass",
                "type": "function",
                "function": {
                  "name": "tasks_upsert",
                  "arguments": "{\"reasoning\": \"e2e: A done, B blocked externally — allow finalize with blocker\", \"subtask_updates\": [{\"content_id\": \"e4a7f48a17f1\", \"status\": \"done\"}], \"blockers\": \"e2e external dependency unavailable for subtask B\", \"allow_finalize_with_blocker\": true}"
                }
              }
            ]
          }
        }
      ]
    }
  },
  "serveEventListeners": [
    {
      "name": "recordState",
      "parameters": {
        "context": "stub-task-ledger-bypass-01::{{request.headers.[x-threlium-thread-root]}}",
        "state": {
          "phase_bypass_upsert_done": "1"
        }
      }
    }
  ]
}
