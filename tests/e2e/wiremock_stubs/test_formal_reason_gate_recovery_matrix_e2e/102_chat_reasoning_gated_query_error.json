{
  "request": {
    "method": "POST",
    "urlPathPattern": "^(/v1/chat/completions|/chat/completions)$",
    "headers": {
      "X-Threlium-Call-Site": {
        "equalTo": "fsm"
      }
    },
    "bodyPatterns": [
      {
        "matches": "(?s).*(openai/threlium_e2e_l0|threlium_e2e_l0).*"
      },
      {
        "contains": "<envelope>"
      },
      {
        "contains": "\"tools\""
      },
      {
        "contains": "PARSE ERROR"
      },
      {
        "contains": "FSM locked"
      },
      {
        "contains": "FORMAL REASON GATE"
      },
      {
        "comment": "memory_query relay after first gate hop must remain in prompt",
        "contains": "turtle_syntax.md SHACL gate recovery"
      },
      {
        "comment": "unified-delta: first formal_reason tool-call reasoning preserved",
        "contains": "e2e matrix: intentional invalid Turtle"
      },
      {
        "contains": "<conversation_delta>"
      },
      {
        "contains": "E2E-FORMAL-REASON-GATE-MATRIX-BODY"
      },
      {
        "doesNotMatch": "(?s).*\"enable_thinking\"\\s*:\\s*false.*"
      }
    ],
    "customMatcher": {
      "name": "state-matcher",
      "parameters": {
        "hasContext": "stub-formal-reason-gate-matrix-01::{{request.headers.[x-threlium-thread-root]}}",
        "hasProperty": "phase_matrix_mq_done",
        "hasNotProperty": "phase_matrix_query_error_done"
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "id": "chatcmpl-e2e-formal-reason-matrix-reasoning-3",
      "object": "chat.completion",
      "created": 0,
      "model": "gpt-4o-mini",
      "choices": [
        {
          "index": 0,
          "finish_reason": "tool_calls",
          "message": {
            "role": "assistant",
            "content": null,
            "tool_calls": [
              {
                "id": "call_e2e_formal_reason_matrix_query_err",
                "type": "function",
                "function": {
                  "name": "formal_reason",
                  "arguments": "{\"reasoning\": \"e2e matrix: valid Turtle but broken SPARQL for second QUERY ERROR under gate\", \"query\": \"PREFIX ex: <http://example.org/> SELECT ?name WHERE { ?p ex:name ?name\", \"shapes_ttl\": \"@prefix sh: <http://www.w3.org/ns/shacl#> .\\n@prefix ex: <http://example.org/> .\\n\\nex:PersonShape a sh:NodeShape ;\\n  sh:targetClass ex:Person ;\\n  sh:property [ sh:path ex:name ; sh:minCount 1 ] .\", \"facts_ttl\": \"@prefix ex: <http://example.org/> .\\n\\nex:alice a ex:Person ;\\n  ex:name \\\"Alice\\\" .\\n\"}"
                }
              }
            ]
          }
        }
      ]
    }
  },
  "serveEventListeners": [
    {
      "name": "recordState",
      "parameters": {
        "context": "stub-formal-reason-gate-matrix-01::{{request.headers.[x-threlium-thread-root]}}",
        "state": {
          "phase_matrix_query_error_done": "1"
        }
      }
    }
  ]
}
