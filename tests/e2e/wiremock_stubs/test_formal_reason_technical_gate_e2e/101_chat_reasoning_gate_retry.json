{
  "request": {
    "method": "POST",
    "urlPathPattern": "^(/v1/chat/completions|/chat/completions)$",
    "headers": {
      "X-Threlium-Call-Site": {
        "equalTo": "reasoning"
      }
    },
    "bodyPatterns": [
      {
        "matches": "(?s).*(openai/threlium_e2e_l0|threlium_e2e_l0).*"
      },
      {
        "contains": "<envelope>"
      },
      {
        "contains": "\"tools\""
      },
      {
        "contains": "QUERY ERROR"
      },
      {
        "contains": "Gate retry counter:"
      },
      {
        "contains": "E2E-FORMAL-REASON-TECH-GATE-BODY"
      }
    ],
    "customMatcher": {
      "name": "state-matcher",
      "parameters": {
        "hasContext": "{{request.headers.[X-Threlium-Thread-Root]}}",
        "hasProperty": "phase_tech_first_done",
        "hasNotProperty": "phase_tech_retry_done"
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "id": "chatcmpl-e2e-formal-reason-tech-gate-reasoning-2",
      "object": "chat.completion",
      "created": 0,
      "model": "gpt-4o-mini",
      "choices": [
        {
          "index": 0,
          "finish_reason": "tool_calls",
          "message": {
            "role": "assistant",
            "content": null,
            "tool_calls": [
              {
                "id": "call_e2e_formal_reason_tech_gate_2",
                "type": "function",
                "function": {
                  "name": "formal_reason",
                  "arguments": "{\"reasoning\": \"e2e: retry with valid SPARQL after QUERY ERROR gate\", \"query\": \"PREFIX ex: <http://example.org/> SELECT ?name WHERE { ?p ex:name ?name }\", \"shapes_ttl\": \"@prefix sh: <http://www.w3.org/ns/shacl#> .\\n@prefix ex: <http://example.org/> .\\n\\nex:PersonShape a sh:NodeShape ;\\n  sh:targetClass ex:Person ;\\n  sh:property [ sh:path ex:name ; sh:minCount 1 ] .\", \"facts_ttl\": \"@prefix ex: <http://example.org/> .\\n\\nex:alice a ex:Person ;\\n  ex:name \\\"Alice\\\" .\\n\"}"
                }
              }
            ]
          }
        }
      ]
    }
  },
  "serveEventListeners": [
    {
      "name": "recordState",
      "parameters": {
        "context": "{{request.headers.[X-Threlium-Thread-Root]}}",
        "state": {
          "phase_tech_retry_done": "1"
        }
      }
    },
    {
      "name": "recordState",
      "parameters": {
        "context": "{{request.headers.[X-Threlium-Thread-Root]}}",
        "list": {
          "addLast": {
            "cs": "{{request.headers.[X-Threlium-Call-Site]}}"
          }
        }
      }
    },
    {
      "name": "recordState",
      "parameters": {
        "context": "{{request.headers.[X-Threlium-Thread-Root]}}",
        "state": {
          "saw_gate_active": "{{#if (contains request.body 'Gate retry counter:')}}1{{else}}{{state context=request.headers.[X-Threlium-Thread-Root] property='saw_gate_active' default='0'}}{{/if}}",
          "saw_query_error": "{{#if (contains request.body 'QUERY ERROR')}}1{{else}}{{state context=request.headers.[X-Threlium-Thread-Root] property='saw_query_error' default='0'}}{{/if}}",
          "saw_query_result": "{{#if (contains request.body 'query_result:')}}1{{else}}{{state context=request.headers.[X-Threlium-Thread-Root] property='saw_query_result' default='0'}}{{/if}}",
          "gated_has_finalize": "{{#if (contains request.body 'Gate retry counter:')}}{{#if (contains (jsonPath request.body '$.tools') 'response_finalize')}}1{{else}}{{state context=request.headers.[X-Threlium-Thread-Root] property='gated_has_finalize' default='0'}}{{/if}}{{else}}{{state context=request.headers.[X-Threlium-Thread-Root] property='gated_has_finalize' default='0'}}{{/if}}"
        }
      }
    }
  ]
}
