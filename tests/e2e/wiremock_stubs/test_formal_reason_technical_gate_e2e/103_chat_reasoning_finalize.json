{
  "request": {
    "method": "POST",
    "urlPathPattern": "^(/v1/chat/completions|/chat/completions)$",
    "headers": {
      "X-Threlium-Call-Site": {
        "equalTo": "reasoning"
      },
      "X-Threlium-Litellm-Req-Seq": {
        "equalTo": "16"
      }
    },
    "bodyPatterns": [
      {
        "matches": "(?s).*(openai/threlium_e2e_l0|threlium_e2e_l0).*"
      },
      {
        "contains": "<envelope>"
      },
      {
        "contains": "\"tools\""
      },
      {
        "contains": "query_result:"
      }
    ],
    "customMatcher": {
      "name": "state-matcher",
      "parameters": {
        "hasContext": "{{request.headers.[X-Threlium-Thread-Root]}}",
        "hasProperty": "active"
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "id": "chatcmpl-e2e-formal-reason-tech-gate-finalize",
      "object": "chat.completion",
      "created": 0,
      "model": "gpt-4o-mini",
      "choices": [
        {
          "index": 0,
          "finish_reason": "tool_calls",
          "message": {
            "role": "assistant",
            "content": null,
            "tool_calls": [
              {
                "id": "call_e2e_response_finalize_tech_gate",
                "type": "function",
                "function": {
                  "name": "response_finalize",
                  "arguments": "{\"reasoning\": \"e2e: answer after QUERY ERROR gate recovery\", \"subject\": \"Re: e2e reply\", \"verification_summary\": \"Recovered from QUERY ERROR via formal_reason retry under gate.\", \"content\": \"e2e-formal-reason-tech-gate-verified-answer\"}"
                }
              }
            ]
          }
        }
      ]
    }
  },
  "serveEventListeners": [
    {
      "name": "recordState",
      "parameters": {
        "context": "{{request.headers.[X-Threlium-Thread-Root]}}",
        "list": {
          "addLast": {
            "cs": "{{request.headers.[X-Threlium-Call-Site]}}"
          }
        }
      }
    },
    {
      "name": "recordState",
      "parameters": {
        "context": "{{#if (contains request.body 'Gate retry counter:')}}saw-gate-active-{{request.headers.[X-Threlium-Thread-Root]}}{{else}}_no_saw_gate_active{{/if}}",
        "list": {
          "addLast": {
            "hit": "1"
          }
        }
      }
    },
    {
      "name": "recordState",
      "parameters": {
        "context": "{{#if (contains request.body 'QUERY ERROR')}}saw-query-error-{{request.headers.[X-Threlium-Thread-Root]}}{{else}}_no_saw_query_error{{/if}}",
        "list": {
          "addLast": {
            "hit": "1"
          }
        }
      }
    },
    {
      "name": "recordState",
      "parameters": {
        "context": "{{#if (contains request.body 'query_result:')}}saw-query-result-{{request.headers.[X-Threlium-Thread-Root]}}{{else}}_no_saw_query_result{{/if}}",
        "list": {
          "addLast": {
            "hit": "1"
          }
        }
      }
    },
    {
      "name": "recordState",
      "parameters": {
        "context": "{{#if (contains request.body 'Gate retry counter:')}}{{#if (contains (jsonPath request.body '$.tools') 'response_finalize')}}gated-has-finalize-{{request.headers.[X-Threlium-Thread-Root]}}{{else}}_no_gated_has_finalize{{/if}}{{else}}_no_gated_has_finalize{{/if}}",
        "list": {
          "addLast": {
            "hit": "1"
          }
        }
      }
    }
  ]
}
