{
  "request": {
    "method": "POST",
    "urlPathPattern": "^(/v1/chat/completions|/chat/completions)$",
    "headers": {
      "X-Threlium-Call-Site": {
        "equalTo": "reasoning"
      },
      "X-Threlium-Litellm-Req-Seq": {
        "equalTo": "8"
      }
    },
    "bodyPatterns": [
      {
        "matches": "(?s).*(openai/threlium_e2e_l0|threlium_e2e_l0).*"
      },
      {
        "contains": "\"tools\""
      },
      {
        "contains": "E2E-REASONING-LITELLM-BODY-MARKER"
      }
    ],
    "customMatcher": {
      "name": "state-matcher",
      "parameters": {
        "hasContext": "stub-reasoning-litellm-live-01::{{request.headers.[X-Threlium-Thread-Root]}}",
        "hasProperty": "phase_length_recovery_e2e"
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "id": "chatcmpl-e2e-length-recovery-finalize",
      "object": "chat.completion",
      "created": 0,
      "model": "gpt-4o-mini",
      "choices": [
        {
          "index": 0,
          "finish_reason": "tool_calls",
          "message": {
            "role": "assistant",
            "content": null,
            "tool_calls": [
              {
                "id": "call_threlium_e2e_length_recovery_finalize",
                "type": "function",
                "function": {
                  "name": "response_finalize",
                  "arguments": "{\"reasoning\": \"e2e: tasks done, finalizing after length recovery\", \"subject\": \"e2e reply\", \"verification_summary\": \"e2e: concise answer after length recovery and tasks ledger\", \"content\": \"ok from llm-mock after length recovery\"}"
                }
              }
            ]
          }
        }
      ]
    }
  },
  "serveEventListeners": [
    {
      "name": "recordState",
      "parameters": {
        "context": "{{request.headers.[X-Threlium-Thread-Root]}}",
        "list": {
          "addLast": {
            "cs": "{{request.headers.[X-Threlium-Call-Site]}}"
          }
        }
      }
    }
  ]
}
