{
  "request": {
    "method": "POST",
    "urlPathPattern": "^(/v1/chat/completions|/chat/completions)$",
    "headers": {
      "X-Threlium-Call-Site": {
        "equalTo": "reasoning"
      },
      "X-Threlium-Litellm-Req-Seq": {
        "equalTo": "22"
      }
    },
    "bodyPatterns": [
      {
        "matches": "(?s).*(openai/threlium_e2e_l0|threlium_e2e_l0).*"
      },
      {
        "contains": "<envelope>"
      },
      {
        "contains": "\"tools\""
      },
      {
        "contains": "E2E-ROLE-INGRESS-TURN2"
      }
    ],
    "customMatcher": {
      "name": "state-matcher",
      "parameters": {
        "hasContext": "{{request.headers.[X-Threlium-Thread-Root]}}",
        "hasProperty": "active"
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "id": "chatcmpl-e2e-unified-roles-turn2",
      "object": "chat.completion",
      "created": 0,
      "model": "gpt-4o-mini",
      "choices": [
        {
          "index": 0,
          "finish_reason": "tool_calls",
          "message": {
            "role": "assistant",
            "content": null,
            "tool_calls": [
              {
                "id": "call_e2e_unified_roles_finalize",
                "type": "function",
                "function": {
                  "name": "response_finalize",
                  "arguments": "{\"reasoning\": \"e2e: turn2 after observe seed thread\", \"subject\": \"Re: e2e unified roles\", \"verification_summary\": \"e2e: IRT whitelist verified\", \"content\": \"e2e-unified-context-roles-verified\"}"
                }
              }
            ]
          }
        }
      ]
    }
  },
  "serveEventListeners": [
    {
      "name": "recordState",
      "parameters": {
        "context": "{{request.headers.[X-Threlium-Thread-Root]}}",
        "list": {
          "addLast": {
            "cs": "{{request.headers.[X-Threlium-Call-Site]}}"
          }
        }
      }
    },
    {
      "name": "recordState",
      "parameters": {
        "context": "{{#if (contains request.body 'E2E-ROLE-INGRESS-SEED')}}saw-seed-{{request.headers.[X-Threlium-Thread-Root]}}{{else}}_no_saw_seed{{/if}}",
        "list": {
          "addLast": {
            "hit": "1"
          }
        }
      }
    },
    {
      "name": "recordState",
      "parameters": {
        "context": "{{#if (contains request.body 'E2E-ROLE-INGRESS-TURN2')}}saw-turn2-{{request.headers.[X-Threlium-Thread-Root]}}{{else}}_no_saw_turn2{{/if}}",
        "list": {
          "addLast": {
            "hit": "1"
          }
        }
      }
    },
    {
      "name": "recordState",
      "parameters": {
        "context": "{{#if (contains request.body 'E2E-OBSERVED-CHUNK')}}saw-observed-{{request.headers.[X-Threlium-Thread-Root]}}{{else}}_no_saw_observed{{/if}}",
        "list": {
          "addLast": {
            "hit": "1"
          }
        }
      }
    },
    {
      "name": "recordState",
      "parameters": {
        "context": "{{#if (contains (regexExtract (jsonPath request.body '$.messages.[-1].content') '(?s)<conversation_history>.*?</conversation_history>') '## User intent')}}hist-user-intent-{{request.headers.[X-Threlium-Thread-Root]}}{{else}}_no_hist_user_intent{{/if}}",
        "list": {
          "addLast": {
            "hit": "1"
          }
        }
      }
    },
    {
      "name": "recordState",
      "parameters": {
        "context": "{{#if (contains (regexExtract (jsonPath request.body '$.messages.[-1].content') '(?s)<conversation_history>.*?</conversation_history>') 'E2E-OBSERVED-CHUNK')}}hist-observed-{{request.headers.[X-Threlium-Thread-Root]}}{{else}}_no_hist_observed{{/if}}",
        "list": {
          "addLast": {
            "hit": "1"
          }
        }
      }
    },
    {
      "name": "recordState",
      "parameters": {
        "context": "{{#if (contains (regexExtract (jsonPath request.body '$.messages.[-1].content') '(?s)<conversation_history>.*?</conversation_history>') 'enrich_fast@localhost')}}hist-leak-{{request.headers.[X-Threlium-Thread-Root]}}{{else}}_no_hist_leak{{/if}}",
        "list": {
          "addLast": {
            "hit": "1"
          }
        }
      }
    }
  ]
}
