{
  "request": {
    "method": "POST",
    "urlPathPattern": "^(/v1/chat/completions|/chat/completions)$",
    "headers": {
      "X-Threlium-Call-Site": {
        "equalTo": "reasoning"
      }
    },
    "bodyPatterns": [
      {
        "matches": "(?s).*(openai/threlium_e2e_l0|threlium_e2e_l0).*"
      },
      {
        "contains": "<envelope>"
      },
      {
        "contains": "\"tools\""
      },
      {
        "contains": "Response buffer"
      }
    ],
    "customMatcher": {
      "name": "state-matcher",
      "parameters": {
        "hasContext": "{{request.headers.[X-Threlium-Thread-Root]}}",
        "hasProperty": "phase_observe",
        "hasNotProperty": "phase_observe_ledger_done"
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "id": "chatcmpl-e2e-tasks-ledger-phase_observe_ledger_done",
      "object": "chat.completion",
      "created": 0,
      "model": "gpt-4o-mini",
      "choices": [
        {
          "index": 0,
          "finish_reason": "tool_calls",
          "message": {
            "role": "assistant",
            "content": null,
            "tool_calls": [
              {
                "id": "call_e2e_tasks_ledger_phase_observe_ledger_done",
                "type": "function",
                "function": {
                  "name": "tasks_upsert",
                  "arguments": "{\"reasoning\": \"e2e: record task completion before finalize\",\"new_subtasks\": [{\"text\": \"Complete the user request\",\"status\": \"done\"}]}"
                }
              }
            ]
          }
        }
      ]
    }
  },
  "serveEventListeners": [
    {
      "name": "recordState",
      "parameters": {
        "context": "{{request.headers.[X-Threlium-Thread-Root]}}",
        "state": {
          "phase_observe_ledger_done": "1"
        }
      }
    },
    {
      "name": "recordState",
      "parameters": {
        "context": "{{request.headers.[X-Threlium-Thread-Root]}}",
        "list": {
          "addLast": {
            "cs": "{{request.headers.[X-Threlium-Call-Site]}}"
          }
        }
      }
    },
    {
      "name": "recordState",
      "parameters": {
        "context": "{{request.headers.[X-Threlium-Thread-Root]}}",
        "state": {
          "saw_seed": "{{#if (contains request.body 'E2E-ROLE-INGRESS-SEED')}}1{{else}}{{state context=request.headers.[X-Threlium-Thread-Root] property='saw_seed' default='0'}}{{/if}}",
          "saw_turn2": "{{#if (contains request.body 'E2E-ROLE-INGRESS-TURN2')}}1{{else}}{{state context=request.headers.[X-Threlium-Thread-Root] property='saw_turn2' default='0'}}{{/if}}",
          "saw_observed": "{{#if (contains request.body 'E2E-OBSERVED-CHUNK')}}1{{else}}{{state context=request.headers.[X-Threlium-Thread-Root] property='saw_observed' default='0'}}{{/if}}",
          "hist_user_intent": "{{#if (contains (regexExtract (jsonPath request.body '$.messages.[-1].content') '(?s)<conversation_history>.*?</conversation_history>') '## User intent')}}1{{else}}{{state context=request.headers.[X-Threlium-Thread-Root] property='hist_user_intent' default='0'}}{{/if}}",
          "hist_observed": "{{#if (contains (regexExtract (jsonPath request.body '$.messages.[-1].content') '(?s)<conversation_history>.*?</conversation_history>') 'E2E-OBSERVED-CHUNK')}}1{{else}}{{state context=request.headers.[X-Threlium-Thread-Root] property='hist_observed' default='0'}}{{/if}}",
          "hist_leak": "{{#if (contains (regexExtract (jsonPath request.body '$.messages.[-1].content') '(?s)<conversation_history>.*?</conversation_history>') 'enrich_fast@localhost')}}1{{else}}{{state context=request.headers.[X-Threlium-Thread-Root] property='hist_leak' default='0'}}{{/if}}"
        }
      }
    }
  ]
}
