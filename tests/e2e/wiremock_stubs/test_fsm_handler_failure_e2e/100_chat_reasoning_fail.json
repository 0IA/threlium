{
  "request": {
    "method": "POST",
    "urlPathPattern": "^(/v1/chat/completions|/chat/completions)$",
    "headers": {
      "X-Threlium-Call-Site": {
        "equalTo": "fsm"
      }
    },
    "bodyPatterns": [
      {
        "matches": "(?s).*(openai/threlium_e2e_l0|threlium_e2e_l0).*"
      },
      {
        "contains": "<envelope>"
      },
      {
        "contains": "\"tools\""
      },
      {
        "contains": "E2E-FSM-HANDLER-FAILURE-BODY"
      }
    ],
    "customMatcher": {
      "name": "state-matcher",
      "parameters": {
        "hasContext": "stub-fsm-handler-failure-01::{{request.headers.[x-threlium-thread-root]}}",
        "hasProperty": "active",
        "hasNotProperty": "phase_failure_seen"
      }
    }
  },
  "response": {
    "status": 500,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "error": {
        "message": "e2e forced reasoning 500",
        "type": "server_error"
      }
    }
  },
  "serveEventListeners": [
    {
      "name": "recordState",
      "parameters": {
        "context": "stub-fsm-handler-failure-01::{{request.headers.[x-threlium-thread-root]}}",
        "state": {
          "phase_failure_seen": "1"
        }
      }
    }
  ]
}
