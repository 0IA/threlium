{
  "metadata": {
    "threlium_stub_tag": "generic-reasoning-phase-1"
  },
  "request": {
    "method": "POST",
    "urlPathPattern": "^(/v1/chat/completions|/chat/completions)$",
    "headers": {
      "X-Threlium-Call-Site": {
        "equalTo": "reasoning"
      }
    },
    "bodyPatterns": [
      {
        "contains": "<envelope>"
      },
      {
        "contains": "\"tools\""
      }
    ],
    "customMatcher": {
      "name": "state-matcher",
      "parameters": {
        "hasContext": "{{request.headers.[X-Threlium-Thread-Root]}}",
        "property": {
          "gen_reasoning": {
            "equalTo": "1"
          },
          "phase": {
            "equalTo": "1"
          }
        }
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "transformers": [
      "response-template"
    ],
    "body": "{\"id\":\"chatcmpl-e2e-generic-reasoning-1\",\"object\":\"chat.completion\",\"created\":0,\"model\":\"gpt-4o-mini\",\"choices\":[{\"index\":0,\"finish_reason\":\"tool_calls\",\"message\":{\"role\":\"assistant\",\"content\":null,\"tool_calls\":[{\"id\":\"call_generic_reasoning_1\",\"type\":\"function\",\"function\":{\"name\":\"{{state context=request.headers.[X-Threlium-Thread-Root] property='p1_tool'}}\",\"arguments\":\"{{{state context=request.headers.[X-Threlium-Thread-Root] property='p1_args'}}}\"}}]}}]}"
  },
  "serveEventListeners": [
    {
      "name": "recordState",
      "parameters": {
        "context": "{{request.headers.[X-Threlium-Thread-Root]}}",
        "state": {
          "phase": "2"
        }
      }
    },
    {
      "name": "recordState",
      "parameters": {
        "context": "{{request.headers.[X-Threlium-Thread-Root]}}",
        "list": {
          "addLast": {
            "cs": "{{request.headers.[X-Threlium-Call-Site]}}"
          }
        }
      }
    },
    {
      "name": "recordState",
      "parameters": {
        "context": "{{#if (contains request.body 'Gate retry counter:')}}saw-reason-gate-{{request.headers.[X-Threlium-Thread-Root]}}{{else}}_no_reason_gate{{/if}}",
        "list": {
          "addLast": {
            "hit": "1"
          }
        }
      }
    },
    {
      "name": "recordState",
      "parameters": {
        "context": "{{request.headers.[X-Threlium-Thread-Root]}}",
        "state": {
          "saw_summary": "{{#if (contains request.body 'E2E-SUM-CONTEXT-MARKER')}}1{{else}}{{state context=request.headers.[X-Threlium-Thread-Root] property='saw_summary' default='0'}}{{/if}}",
          "saw_raw_pad": "{{#if (contains request.body 'PPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPP')}}1{{else}}{{state context=request.headers.[X-Threlium-Thread-Root] property='saw_raw_pad' default='0'}}{{/if}}"
        }
      }
    },
    {
      "name": "recordState",
      "parameters": {
        "context": "{{request.headers.[X-Threlium-Thread-Root]}}",
        "state": {
          "saw_alpha": "{{#if (contains request.body 'ZZNODEALPHA')}}1{{else}}{{state context=request.headers.[X-Threlium-Thread-Root] property='saw_alpha' default='0'}}{{/if}}",
          "saw_beta": "{{#if (contains request.body 'ZZNODEBETA')}}1{{else}}{{state context=request.headers.[X-Threlium-Thread-Root] property='saw_beta' default='0'}}{{/if}}",
          "saw_rel": "{{#if (contains request.body 'ZZRELMARKER')}}1{{else}}{{state context=request.headers.[X-Threlium-Thread-Root] property='saw_rel' default='0'}}{{/if}}"
        }
      }
    },
    {
      "name": "recordState",
      "parameters": {
        "context": "{{request.headers.[X-Threlium-Thread-Root]}}",
        "state": {
          "saw_gate_active": "{{#if (contains request.body 'Gate retry counter:')}}1{{else}}{{state context=request.headers.[X-Threlium-Thread-Root] property='saw_gate_active' default='0'}}{{/if}}",
          "saw_query_result": "{{#if (contains request.body 'query_result:')}}1{{else}}{{state context=request.headers.[X-Threlium-Thread-Root] property='saw_query_result' default='0'}}{{/if}}"
        }
      }
    },
    {
      "name": "recordState",
      "parameters": {
        "context": "{{request.headers.[X-Threlium-Thread-Root]}}",
        "state": {
          "saw_conforms_false": "{{#if (contains request.body 'conforms: False')}}1{{else}}{{state context=request.headers.[X-Threlium-Thread-Root] property='saw_conforms_false' default='0'}}{{/if}}",
          "saw_violations": "{{#if (contains request.body 'violations:')}}1{{else}}{{state context=request.headers.[X-Threlium-Thread-Root] property='saw_violations' default='0'}}{{/if}}"
        }
      }
    },
    {
      "name": "recordState",
      "parameters": {
        "context": "{{request.headers.[X-Threlium-Thread-Root]}}",
        "state": {
          "saw_query_error": "{{#if (contains request.body 'QUERY ERROR')}}1{{else}}{{state context=request.headers.[X-Threlium-Thread-Root] property='saw_query_error' default='0'}}{{/if}}",
          "gated_has_finalize": "{{#if (contains request.body 'Gate retry counter:')}}{{#if (contains (jsonPath request.body '$.tools') 'response_finalize')}}1{{else}}{{state context=request.headers.[X-Threlium-Thread-Root] property='gated_has_finalize' default='0'}}{{/if}}{{else}}{{state context=request.headers.[X-Threlium-Thread-Root] property='gated_has_finalize' default='0'}}{{/if}}"
        }
      }
    }
  ]
}
