{
  "metadata": { "threlium_stub_tag": "generic-embeddings-batch-query" },
  "request": {
    "method": "POST",
    "urlPathPattern": "^(/v1/embeddings|/embeddings)$",
    "headers": { "X-Threlium-Thread-Root": { "matches": ".+" } },
    "bodyPatterns": [ { "contains": "threlium_e2e_embed" } ]
  },
  "response": {
    "status": 200,
    "headers": { "Content-Type": "application/json" },
    "transformers": [ "response-template" ],
    "body": "{{parseJson request.body 'r'}}{\"object\":\"list\",\"model\":\"openai/threlium_e2e_embed\",\"usage\":{\"prompt_tokens\":1,\"total_tokens\":1},\"data\":[{{#each r.input as |txt|}}{{#unless @first}},{{/unless}}{\"object\":\"embedding\",\"index\":{{@index}},\"embedding\":[{{#arrayJoin ',' (range 0 1535) as |d|}}0.01{{/arrayJoin}}]}{{/each}}]}"
  },
  "serveEventListeners": [
    { "name": "recordState",
      "parameters": { "context": "{{request.headers.[X-Threlium-Thread-Root]}}",
        "list": { "addLast": { "cs": "{{request.headers.[X-Threlium-Call-Site]}}" } } } },
    { "name": "recordState",
      "parameters": {
        "context": "{{#if (contains request.body 'E2E-MEMORY-QUERY-MARKER')}}saw-memory-query-marker{{else}}_no_qmarker{{/if}}",
        "list": { "addLast": { "hit": "1" } } } }
  ]
}
