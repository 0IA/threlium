{
  "request": {
    "method": "POST",
    "urlPath": "/__threlium/e2e/state/setup"
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "ok": true,
      "context": "{{jsonPath request.body '$.correlation_key'}}"
    }
  },
  "serveEventListeners": [
    {
      "name": "recordState",
      "parameters": {
        "context": "{{jsonPath request.body '$.correlation_key'}}",
        "state": {
          "active": "1",
          "search_for": "{{jsonPath request.body '$.search_for' default='__NO_SEARCH__'}}"
        }
      }
    }
  ]
}
