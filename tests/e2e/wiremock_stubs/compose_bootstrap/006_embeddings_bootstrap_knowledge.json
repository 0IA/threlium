{
  "request": {
    "method": "POST",
    "urlPathPattern": "^(/v1/embeddings|/embeddings)$",
    "headers": {
      "X-Threlium-Thread-Root": {
        "equalTo": "e2e-bootstrap"
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "transformers": [
      "response-template"
    ],
    "body": "{{parseJson request.body 'r'}}{\"object\":\"list\",\"model\":\"openai/threlium_e2e_embed\",\"usage\":{\"prompt_tokens\":1,\"total_tokens\":1},\"data\":[{{#each r.input as |txt|}}{{#unless @first}},{{/unless}}{\"object\":\"embedding\",\"index\":{{@index}},\"embedding\":[{{#arrayJoin ',' (range 0 1535) as |d|}}0.02{{/arrayJoin}}]}{{/each}}]}"
  },
  "serveEventListeners": [
    {
      "name": "recordState",
      "parameters": {
        "context": "e2e-bootstrap",
        "list": {
          "addLast": {
            "cs": "{{request.headers.[X-Threlium-Call-Site]}}"
          }
        }
      }
    },
    {
      "name": "recordState",
      "parameters": {
        "context": "e2e-bootstrap",
        "state": {
          "saw_match": "1"
        }
      }
    }
  ]
}
