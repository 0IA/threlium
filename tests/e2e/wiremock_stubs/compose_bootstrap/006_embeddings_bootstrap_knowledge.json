{
  "id": "a0b1c2d3-e4f5-6a7b-8c9d-0e1f2a3b4c5d",
  "request": {
    "method": "POST",
    "urlPathPattern": "^(/v1/embeddings|/embeddings)$",
    "headers": {
      "X-Threlium-Thread-Root": {
        "equalTo": "e2e-bootstrap"
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "transformers": [
      "response-template"
    ],
    "body": "{{parseJson request.body 'r'}}{\"object\":\"list\",\"model\":\"openai/threlium_e2e_embed\",\"usage\":{\"prompt_tokens\":1,\"total_tokens\":1},\"data\":[{{#each r.input as |txt|}}{{#unless @first}},{{/unless}}{\"object\":\"embedding\",\"index\":{{@index}},\"embedding\":[{{#arrayJoin ',' (range 0 1535) as |d|}}{{#if @first}}0.02{{else}}0.0{{/if}}{{/arrayJoin}}]}{{/each}}]}"
  }
}
