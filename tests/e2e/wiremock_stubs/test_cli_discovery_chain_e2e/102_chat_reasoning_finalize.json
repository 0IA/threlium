{
  "request": {
    "method": "POST",
    "urlPathPattern": "^(/v1/chat/completions|/chat/completions)$",
    "headers": {
      "X-Threlium-Call-Site": {
        "equalTo": "reasoning"
      },
      "X-Threlium-Litellm-Req-Seq": {
        "equalTo": "10"
      }
    },
    "bodyPatterns": [
      {
        "matches": "(?s).*(openai/threlium_e2e_l0|threlium_e2e_l0).*"
      },
      {
        "contains": "<envelope>"
      },
      {
        "contains": "\"tools\""
      },
      {
        "contains": "E2E-CLI-DISCOVERY-STDOUT-MARKER"
      }
    ],
    "customMatcher": {
      "name": "state-matcher",
      "parameters": {
        "hasContext": "stub-cli-discovery-chain-01::{{request.headers.[X-Threlium-Thread-Root]}}",
        "hasProperty": "active"
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "transformers": [
      "response-template"
    ],
    "jsonBody": {
      "id": "chatcmpl-e2e-live-cli-allow-egress",
      "object": "chat.completion",
      "created": 0,
      "model": "gpt-4o-mini",
      "choices": [
        {
          "index": 0,
          "finish_reason": "tool_calls",
          "message": {
            "role": "assistant",
            "content": null,
            "tool_calls": [
              {
                "id": "call_threlium_e2e_egress_after_allow",
                "type": "function",
                "function": {
                  "name": "response_finalize",
                  "arguments": "{\"reasoning\": \"e2e: finalizing after discovery chain cli\", \"subject\": \"e2e reply\", \"verification_summary\": \"e2e: rg discovery stdout verified\", \"content\": \"e2e-cli-discovery-chain-verified\"}"
                }
              }
            ]
          }
        }
      ]
    }
  },
  "serveEventListeners": [
    {
      "name": "recordState",
      "parameters": {
        "context": "{{#if (contains request.body 'E2E-CLI-DISCOVERY-STDOUT-MARKER')}}saw-cli-stdout-{{request.headers.[X-Threlium-Thread-Root]}}{{else}}_no_saw_cli_stdout{{/if}}",
        "list": {
          "addLast": {
            "hit": "1"
          }
        }
      }
    }
  ]
}
