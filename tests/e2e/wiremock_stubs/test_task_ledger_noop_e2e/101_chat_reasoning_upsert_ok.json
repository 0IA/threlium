{
  "request": {
    "method": "POST",
    "urlPathPattern": "^(/v1/chat/completions|/chat/completions)$",
    "headers": {
      "X-Threlium-Call-Site": {
        "equalTo": "reasoning"
      }
    },
    "bodyPatterns": [
      {
        "matches": "(?s).*(openai/threlium_e2e_l0|threlium_e2e_l0).*"
      },
      {
        "contains": "<envelope>"
      },
      {
        "contains": "\"tools\""
      },
      {
        "comment": "After the no-op was guided back through enrich_fast, the LLM reads the real content_id from <task_state> and updates it correctly. content_id 9d9d077ccc56 = 'Reproduce the tasks_upsert validation error'.",
        "contains": "E2E-TASK-LEDGER-NOOP-BODY"
      },
      {
        "comment": "STRONG assertion: the rendered no-op guidance (ingress/tasks_upsert_noop.j2) must have reached reasoning via enrich_fast. If it didn't propagate, this stub won't match → no finalize → test fails (guarding the soft-guidance path, not just 'recovered somehow').",
        "contains": "TASKS_UPSERT had no effect"
      }
    ],
    "customMatcher": {
      "name": "state-matcher",
      "parameters": {
        "hasContext": "stub-task-ledger-noop-01::{{request.headers.[X-Threlium-Thread-Root]}}",
        "hasProperty": "phase_upsert_noop_done",
        "hasNotProperty": "phase_upsert_ok_done"
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "id": "chatcmpl-e2e-task-ledger-noop-reasoning-2-upsert-ok",
      "object": "chat.completion",
      "created": 0,
      "model": "gpt-4o-mini",
      "choices": [
        {
          "index": 0,
          "finish_reason": "tool_calls",
          "message": {
            "role": "assistant",
            "content": null,
            "tool_calls": [
              {
                "id": "call_e2e_upsert_ok",
                "type": "function",
                "function": {
                  "name": "tasks_upsert",
                  "arguments": "{\"reasoning\": \"e2e: update the real seeded subtask to done\", \"subtask_updates\": [{\"content_id\": \"9d9d077ccc56\", \"status\": \"done\"}]}"
                }
              }
            ]
          }
        }
      ]
    }
  },
  "serveEventListeners": [
    {
      "name": "recordState",
      "parameters": {
        "context": "stub-task-ledger-noop-01::{{request.headers.[X-Threlium-Thread-Root]}}",
        "state": {
          "phase_upsert_ok_done": "1"
        }
      }
    },
    {
      "name": "recordState",
      "parameters": {
        "context": "{{request.headers.[X-Threlium-Thread-Root]}}",
        "list": {
          "addLast": {
            "cs": "{{request.headers.[X-Threlium-Call-Site]}}"
          }
        }
      }
    }
  ]
}
