{
  "request": {
    "method": "POST",
    "urlPathPattern": "^(/v1/chat/completions|/chat/completions)$",
    "headers": {
      "X-Threlium-Call-Site": {
        "equalTo": "reasoning"
      }
    },
    "bodyPatterns": [
      {
        "matches": "(?s).*(openai/threlium_e2e_l0|threlium_e2e_l0).*"
      },
      {
        "contains": "<envelope>"
      },
      {
        "contains": "\"tools\""
      },
      {
        "comment": "First reasoning: a NO-OP tasks_upsert (only reasoning, no new_subtasks and no subtask_updates). Pre-fix this raised a hard 'no actions' error and re-dispatched forever (production livelock). The handler must instead render a guidance notice and relay it back through enrich_fast (no ledger mutation), so reasoning can correct itself.",
        "contains": "E2E-TASK-LEDGER-NOOP-BODY"
      }
    ],
    "customMatcher": {
      "name": "state-matcher",
      "parameters": {
        "hasContext": "stub-task-ledger-noop-01::{{request.headers.[X-Threlium-Thread-Root]}}",
        "hasProperty": "active",
        "hasNotProperty": "phase_upsert_noop_done"
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "id": "chatcmpl-e2e-task-ledger-noop-reasoning-1-empty",
      "object": "chat.completion",
      "created": 0,
      "model": "gpt-4o-mini",
      "choices": [
        {
          "index": 0,
          "finish_reason": "tool_calls",
          "message": {
            "role": "assistant",
            "content": null,
            "tool_calls": [
              {
                "id": "call_e2e_upsert_noop",
                "type": "function",
                "function": {
                  "name": "tasks_upsert",
                  "arguments": "{\"reasoning\": \"e2e: no-op tasks_upsert — only reasoning, no new_subtasks and no subtask_updates (must be guided back, not hard-errored)\"}"
                }
              }
            ]
          }
        }
      ]
    }
  },
  "serveEventListeners": [
    {
      "name": "recordState",
      "parameters": {
        "context": "stub-task-ledger-noop-01::{{request.headers.[X-Threlium-Thread-Root]}}",
        "state": {
          "phase_upsert_noop_done": "1"
        }
      }
    },
    {
      "name": "recordState",
      "parameters": {
        "context": "{{request.headers.[X-Threlium-Thread-Root]}}",
        "list": {
          "addLast": {
            "cs": "{{request.headers.[X-Threlium-Call-Site]}}"
          }
        }
      }
    }
  ]
}
