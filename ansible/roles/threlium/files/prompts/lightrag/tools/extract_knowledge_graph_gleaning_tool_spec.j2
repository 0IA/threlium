{#- tool_spec for LightRAG gleaning (continue/second pass) — fully standalone, no include -#}
{
  "type": "function",
  "function": {
    "name": "extract_knowledge_graph_gleaning",
    "description": "Gleaning pass: call once; no assistant text outside tool_calls; do not emit delimiter lines in message content. Report ONLY items missed, truncated, or incorrectly formatted in the previous pass; do not repeat items already extracted correctly. Return empty arrays for both fields when nothing remains to add or fix (gleaning complete).",
    "parameters": {
      "type": "object",
      "properties": {
        "entities": {
          "type": "array",
          "description": "Entities missed or corrected since the previous pass; empty when none remain.",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "type": { "type": "string", "minLength": 1 },
              "description": { "type": "string", "minLength": 1 }
            },
            "required": ["name", "type", "description"],
            "additionalProperties": false
          }
        },
        "relationships": {
          "type": "array",
          "description": "Relationships missed or corrected since the previous pass; empty when none remain.",
          "items": {
            "type": "object",
            "properties": {
              "source": { "type": "string", "minLength": 1 },
              "target": { "type": "string", "minLength": 1 },
              "keywords": { "type": "string" },
              "description": { "type": "string", "minLength": 1 }
            },
            "required": [
              "source",
              "target",
              "keywords",
              "description"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": ["entities", "relationships"],
      "additionalProperties": false
    }
  }
}
