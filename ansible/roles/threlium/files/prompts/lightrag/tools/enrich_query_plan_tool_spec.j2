{#- tool_spec for enrich query-plan formulation (tool_choice=required, score 1) — standalone -#}
{
  "type": "function",
  "function": {
    "name": "enrich_query_plan",
    "description": "Tool-only: call once; no assistant text outside tool_calls. Formulate a single English retrieval question for the LightRAG knowledge graph that fills information gaps in the conversation and surfaces related entities and relations.",
    "parameters": {
      "type": "object",
      "properties": {
        "formulated_query": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000,
          "description": "The graph query text used verbatim by the operator; English; concise; entities/relations/verification questions, not a restatement of the whole brief."
        }
      },
      "required": ["formulated_query"],
      "additionalProperties": false
    }
  }
}
