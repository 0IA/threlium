{#- tool_spec for LightRAG first-pass entity extraction -#}
{
  "type": "function",
  "function": {
    "name": "extract_knowledge_graph",
    "description": "First-pass extraction: call once; no assistant text outside tool_calls; do not emit delimiter lines in message content. Extract every entity and relationship you can identify in the input text. Use an empty array only for a category that genuinely has no items.",
    "parameters": {
      "type": "object",
      "properties": {
        "entities": {
          "type": "array",
          "description": "All entities found in the input text on this first pass.",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "type": { "type": "string", "minLength": 1 },
              "description": { "type": "string", "minLength": 1 }
            },
            "required": ["name", "type", "description"],
            "additionalProperties": false
          }
        },
        "relationships": {
          "type": "array",
          "description": "All relationships found in the input text on this first pass.",
          "items": {
            "type": "object",
            "properties": {
              "source": { "type": "string", "minLength": 1 },
              "target": { "type": "string", "minLength": 1 },
              "keywords": { "type": "string" },
              "description": { "type": "string", "minLength": 1 }
            },
            "required": [
              "source",
              "target",
              "keywords",
              "description"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": ["entities", "relationships"],
      "additionalProperties": false
    }
  }
}
