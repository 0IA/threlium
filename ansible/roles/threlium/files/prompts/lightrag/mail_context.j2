{#- Renders a list of EmailMessage objects as chronological mail context.
    Used for thread/global/hypotheses mail context strings (not a MIME CID).
    Body is the message's <history> part(s) (history_text filter), not the raw
    first text/plain (which may be the <system> payload). -#}
{% for msg in messages %}
--- message {{ loop.index }} ---
From: {{ msg.get('From', '') }}
Date: {{ msg.get('Date', '') }}
Subject: {{ msg.get('Subject', '') }}
{% set body = msg | history_text %}
{% if body %}
{{ body }}
{% endif %}
{% endfor %}
