{#- Renders a list of EmailMessage objects as chronological context.
    Used for <unified-mail-context>, <thread-memory>, <global-memory>.
    Tiered rendering via tier_assignments dict (index → tier level):
    - Tier 1: full body
    - Tier 2: headers + truncated body (preview)
    - Tier 3: headers only (From/Date/Subject)
    When tier_assignments is empty, all messages render with full body (backwards-compatible).
    Service transitions are excluded at collection level; service_stages is a safety fallback. -#}
{% set body_preview_chars = preview_chars %}
{% set total = total_messages %}
{% set service_stages = service_stage_mailboxes | default([]) %}
{% set t1_count = tier_assignments.values() | select('equalto', 1) | list | length if tier_assignments else 0 %}
{% set t2_count = tier_assignments.values() | select('equalto', 2) | list | length if tier_assignments else 0 %}
{% if tier_assignments and t1_count > 0 %}
[context: {{ total }} messages total, {{ t1_count }} full, {{ t2_count }} summarized, rest headers-only. Service messages collapsed. Use reflect if needed information is in summarized/header messages.]
{% endif %}
{% for msg in messages %}
{% set to_addr = msg.get('To', '') %}
{% set tier = tier_assignments.get(loop.index0, 1) if tier_assignments else 1 %}
{% if to_addr in service_stages %}
--- message {{ loop.index }} [service: {{ to_addr.split('@')[0] }}] ---
{% elif tier == 1 %}
{% set msg_type = tier_assignments_types.get(loop.index0, 'system') if tier_assignments_types is defined else 'system' %}
--- message {{ loop.index }} [type: {{ msg_type }}] ---
From: {{ msg.get('From', '') }}
To: {{ to_addr }}
Date: {{ msg.get('Date', '') }}
Subject: {{ msg.get('Subject', '') }}
{% set part = msg.get_body(preferencelist=('plain', 'html')) %}
{% if part %}
{{ part.get_content() }}
{% endif %}
{% elif tier == 2 %}
{% set msg_type = tier_assignments_types.get(loop.index0, 'system') if tier_assignments_types is defined else 'system' %}
--- message {{ loop.index }} [type: {{ msg_type }}, summary] ---
From: {{ msg.get('From', '') }}
Date: {{ msg.get('Date', '') }}
Subject: {{ msg.get('Subject', '') }}
{% set part = msg.get_body(preferencelist=('plain', 'html')) %}
{% if part %}
{{ part.get_content()[:body_preview_chars] }}...
{% endif %}
{% else %}
{% set msg_type = tier_assignments_types.get(loop.index0, 'system') if tier_assignments_types is defined else 'system' %}
--- message {{ loop.index }} [type: {{ msg_type }}, header] ---
From: {{ msg.get('From', '') }}
Date: {{ msg.get('Date', '') }}
Subject: {{ msg.get('Subject', '') }}
{% endif %}
{% endfor %}
