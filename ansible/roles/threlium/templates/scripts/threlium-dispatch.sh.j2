#!/bin/sh
# Managed by Ansible — dispatch workers for unread messages in a stage.
# Primary: fdm pipe runs `notmuch insert && threlium-dispatch.sh` (THRELIUM_STAGE from that shell).
# After successful worker exit: `threlium-sweep@<stage>:<thread_id>.service` (OnSuccess on worker)
# runs the same script with %i → `threlium-dispatch.sh <stage>:<thread_id>`.
# Fail-fast: любой ненулевой код notmuch search или systemctl — скрипт завершается с ошибкой
# (stderr не подавляется). Ошибка dispatch не откатывает уже выполненный notmuch insert.
# Usage: THRELIUM_STAGE=<stage> threlium-dispatch.sh
#   or:  threlium-dispatch.sh <stage>:<thread_id>  (same %i as sweep unit / manual run)
# Trade-off: один вызов systemctl со списком unit-ов — см. systemctl(1); следующий insert или sweep снова вызовут dispatch.
# Нить ищем через folder: (prefix-term относительно database.path) — быстрее, чем to:<stage>@localhost.
set -eu
# fdm / MDA может наследовать stripped env: без XDG_RUNTIME_DIR/DBUS systemctl --user падает.
_uid="$(id -ru)"
export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/${_uid}}"
if [ -z "${DBUS_SESSION_BUS_ADDRESS:-}" ] && [ -S "${XDG_RUNTIME_DIR}/bus" ]; then
    export DBUS_SESSION_BUS_ADDRESS="unix:path=${XDG_RUNTIME_DIR}/bus"
fi
if [ -n "${1:-}" ]; then
    STAGE="${1%%:*}"
else
    STAGE="${THRELIUM_STAGE:-}"
fi
[ -z "$STAGE" ] && exit 0
export NOTMUCH_CONFIG="{{ threlium_posix_home }}/.notmuch-config"
UNITS=""
for tid in $(notmuch search --exclude=false --output=threads "tag:unread AND folder:${STAGE}/Maildir"); do
    UNITS="$UNITS threlium-work@${STAGE}:${tid#thread:}.service"
done
if [ -n "$UNITS" ]; then
    # НЕ делаем reset-failed: в проде (StartLimitIntervalSec=0) backoff-эскалация RestartSec должна
    # ПЕРЕЖИВАТЬ повторные dispatch'и — рестарты лишь снижают частоту ретраев (а reset сбрасывал бы
    # эскалацию). В e2e (короткое StartLimitIntervalSec + burst=2) накопление стартов в окне — это и
    # есть потолок «1 рестарт»; окно истекает между разнесёнными dispatch'ами, поэтому свежий старт
    # чистый без reset-failed. `start` сам активирует юнит из failed (reset нужен лишь после
    # start-limit, а его в e2e мы и хотим как терминальный fail). См. group_vars/e2e.yml.
    # shellcheck disable=SC2086
    systemctl --user start --no-block $UNITS
fi
